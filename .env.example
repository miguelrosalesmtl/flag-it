# Copy to .env and adjust. Real environment variables always override these
# (in Kubernetes, values come from ConfigMaps and Secrets, not this file).

# --- App ---
APP_ENV=development          # development | staging | production
APP_DEBUG=true               # text logs + verbose errors when true
LOG_LEVEL=info               # debug | info | warn | error
# INSTANCE_ID is set per-pod in Kubernetes via the downward API (metadata.name).
INSTANCE_ID=

# --- HTTP server ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=10s
SERVER_IDLE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=15s
# Required in production. Guards write endpoints via the X-API-Key header.
API_KEY=
# Cache SDK-key lookups to avoid a Postgres hit per evaluation. Revokes flush the
# local cache immediately; other replicas converge within this TTL. 0 disables.
SDK_KEY_CACHE_TTL=30s
# How often buffered evaluation counts are flushed to the rollup stats table.
ANALYTICS_FLUSH_INTERVAL=30s
# Browser origins allowed to call the API (comma separated). "*" = any (dev).
# Restrict to your UI's origin(s) in production, e.g. https://app.example.com
CORS_ALLOWED_ORIGINS=*

# --- Postgres (source of truth) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_SSLMODE=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME=1h
POSTGRES_MAX_CONN_IDLE_TIME=30m

# --- Redis (pub/sub bus) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CHANNEL=featureflag:changes
