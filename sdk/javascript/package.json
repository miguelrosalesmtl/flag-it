{
  "name": "@flag-it/sdk",
  "version": "0.1.0",
  "description": "Thin JavaScript/TypeScript SDK for the flag-it feature-flag service (server-side evaluation).",
  "type": "module",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "feature-flags",
    "flag-it",
    "sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
