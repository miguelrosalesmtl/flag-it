# Local development configuration.
#
# Copy to `.env` and edit. A Vite plugin (vite/runtime-config.ts) turns this into
# public/config.json when the dev server starts, which is what the app actually
# boots from — the same path production uses.
#
# These are the SAME variable names docker/entrypoint.sh reads in deployment, so
# there is one vocabulary from your laptop to production.
#
# Everything here is served to the browser in plain text via /config.json.
# It is PUBLIC. Never put a secret in it — an SPA has no server side.

# Where the API lives. Relative ("/api") or absolute ("https://api.example.com").
APP_API_URL=/api

# development | staging | production. Drives the environment banner.
APP_ENVIRONMENT=development

# Serve the app from MSW fixtures instead of a real backend.
# Leave true to run with no backend at all. Set false to hit APP_API_URL for real.
APP_ENABLE_MOCKING=true
